# First two lines only work with SIP turned off and yabai can run sudo without password
yabai -m signal --add event=dock_did_restart action="sudo yabai --load-sa"
sudo yabai --load-sa

# Configure Yabai settings
yabai -m config \
  mouse_follows_focus          on \
  focus_follows_mouse          autoraise \
  window_origin_display        default \
  window_placement             second_child \
  window_zoom_persist          on \
  window_shadow                float \
  window_animation_duration    0.0 \
  window_animation_frame_rate  120 \
  window_opacity_duration      0.0 \
  active_window_opacity        1.0 \
  normal_window_opacity        1.0 \
  window_opacity               on \
  insert_feedback_color        0xffd75f5f \
  split_ratio                  0.50 \
  split_type                   auto \
  auto_balance                 off \
  top_padding                  08 \
  bottom_padding               08 \
  left_padding                 08 \
  right_padding                08 \
  window_gap                   10 \
  layout                       bsp \
  mouse_modifier               alt \
  mouse_action1                move \
  mouse_action2                resize \
  mouse_drop_action            swap

# List of apps that will start in float
blacklist=("System Settings" "Calculator" "Activity Monitor"	\ 
					"FaceTime" "Splashtop Business" "Microsoft OneNote"	\
					"Stickies")

for app in ${blacklist[@]}; do
  yabai -m rule --add app=$app manage=off
done

# Setting border for active and inactive windows
borders active_color=0xffCAD3F5 inactive_color=0xff474B61 width=3.0 2>/dev/null 1>&2 &